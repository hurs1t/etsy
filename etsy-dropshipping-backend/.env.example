# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_... # Paylaştığınız keyi buraya yapıştırın
STRIPE_WEBHOOK_SECRET=whsec_... # Stripe Dashboard > Developers > Webhooks kısmından alınır

# Plan Price IDs (ÖNEMLİ: prod_ ile başlayanlar ürün ID'sidir, Checkout için price_ ile başlayanları kullanmalısınız)
STRIPE_PRICE_STARTER=price_... # Silver Plan Price ID
STRIPE_PRICE_PRO=price_... # Gold Plan Price ID
STRIPE_PRICE_BUSINESS=price_... # Platinum Plan Price ID

# URLs
FRONTEND_URL=https://etsy-gp8...vercel.app # Vercel'deki sitenizin adresi
BACKEND_URL=https://etsy-api...vercel.app # Deployed api adresiniz

# Supabase
SUPABASE_URL=...
SUPABASE_KEY=...
SUPABASE_SERVICE_ROLE=...
